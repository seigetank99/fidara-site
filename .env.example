# Contact email delivery (required)
CONTACT_TO=inbox@example.com
CONTACT_FROM=website@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Public site identity and SEO
PUBLIC_SITE_URL=https://www.fidaragroup.com
PUBLIC_GA4_ID=
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_BING_SITE_VERIFICATION=

# Cloudflare Turnstile (set both or neither)
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Analytics and observability (optional)
PUBLIC_CLIENT_ERROR_REPORTING=false
CLIENT_ERROR_WEBHOOK=
CONTACT_ALERT_WEBHOOK=

# Client portal
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=fidara-client-documents

SESSION_COOKIE_NAME=fidara_session

# Optional launch-gate budget overrides, in kilobytes
MAX_JS_KB=380
MAX_CSS_KB=80
